# Required for Railway
RAILWAY_ENVIRONMENT=production
DJANGO_SECRET_KEY=your-super-secret-key-at-least-50-characters-long-and-complex
DATABASE_URL=postgresql://user:password@host:5432/dbname  # Auto-provided by Railway
REDIS_URL=redis://host:6379  # Auto-provided by Railway

# Security
DJANGO_ALLOWED_HOSTS=.railway.app,.up.railway.app,mfalmebits.com
CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app,https://mfalmebits.com
DEBUG=False

# Email (Optional - Use SendGrid on Railway)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@mfalmebits.com

# Stripe (Optional)
STRIPE_PUBLIC_KEY=pk_live_your-key
STRIPE_SECRET_KEY=sk_live_your-key